{
  "name": "study-dashboard",
  "version": "0.1.9",
  "private": true,
  "description": "StudyFlow desktop app",
  "author": "StudyFlow",
  "main": "electron/main.cjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/shreyasnayak45/AI-Study-Dashboard---Windows.git"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "desktop:dev": "node electron/dev.cjs",
    "desktop:build": "node electron/desktop-build.cjs",
    "desktop:publish": "node electron/desktop-build.cjs --publish always"
  },
  "build": {
    "appId": "com.studyflow.desktop",
    "productName": "StudyFlow",
    "executableName": "StudyFlow",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/main.cjs",
      "electron/preload.cjs",
      "build/logo.ico",
      ".next/standalone/**",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "asarUnpack": [
      ".next/standalone/**"
    ],
    "extraResources": [
      {
        "from": "build/logo.ico",
        "to": "logo.ico"
      }
    ],
    "win": {
      "icon": "build/logo.ico",
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": true,
      "installerHeader": "build/installerHeader.bmp",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/installerSidebar.bmp",
      "installerIcon": "build/logo.ico",
      "uninstallerIcon": "build/logo.ico",
      "include": "build/installer.nsh",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "StudyFlow"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "shreyasnayak45",
        "repo": "AI-Study-Dashboard---Windows",
        "releaseType": "release"
      }
    ]
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.3",
    "clsx": "^2.1.1",
    "electron-updater": "^6.6.2",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "next": "16.2.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "resend": "^6.12.3",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.5",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
